    "section3Features": {
      "type": "component",
      "repeatable": true,
      "component": "landing.ua-feature"
    },
    "section4Eyebrow": {
      "type": "string",
      "default": "Creative Services"
    },
    "section4Title": {
      "type": "string",
      "required": true
