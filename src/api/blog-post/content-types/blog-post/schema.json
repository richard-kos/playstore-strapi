{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog",
    "description": "Blog articles (same fields as landing insight posts) for playstore-mvp /blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "string",
      "required": true
    },
    "postDate": {
      "type": "datetime"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "link": {
      "type": "string",
      "required": true
    },
    "authorName": {
      "type": "string"
    },
    "authorAvatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Author headshot (square works best)"
    }
  }
}
