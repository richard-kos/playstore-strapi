{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog",
    "description": "Blog articles (same fields as landing insight posts) for playstore-mvp /blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-category.blog-category",
      "inversedBy": "blog_posts",
      "required": true,
      "description": "Select existing categories or create a new Blog category entry from the relation picker"
    },
    "postDate": {
      "type": "datetime"
    },
    "detail": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      },
      "required": false,
      "description": "Full article body: HTML from CKEditor (images, video embeds, links, fonts, colors)"
    },
    "authorName": {
      "type": "string"
    },
    "authorAvatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Author headshot (square works best)"
    },
    "authorDetail": {
      "type": "string",
      "required": true,
      "description": "Author bio / extended byline (plain text)"
    }
  }
}
